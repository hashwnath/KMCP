# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# OpenSearch
OPENSEARCH_ENDPOINT=
OPENSEARCH_COLLECTION_NAME=knowledgemcp

# Embeddings (choose one)
EMBEDDING_PROVIDER=bedrock
OPENAI_API_KEY=
BEDROCK_MODEL_ID=amazon.titan-embed-text-v2:0

# MCP Server
MCP_SERVER_PORT=8000
MCP_SERVER_HOST=0.0.0.0
MCP_BASE_URL=http://localhost:8000
USER_AGENT=KnowledgeMCP/1.0 (+https://knowledgemcp.io)

# Crawler
CRAWL_DELAY_SECONDS=0.5
DEBUG=false

# Auth
ADMIN_API_KEY=
JWT_SECRET_KEY=
SKIP_AUTH=false
SIGNUP_CODE=
SES_FROM_EMAIL=
APP_BASE_URL=https://app.knowledgemcp.io
FRONTEND_ORIGIN=https://app.knowledgemcp.io

# Rate Limiting
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=30
MAX_QUERIES_PER_HOUR=100
MAX_DOCS_PER_TENANT=500

# SQS Queues
CRAWL_QUEUE_URL=
INDEX_QUEUE_URL=

# DynamoDB Tables
TENANTS_TABLE=knowledgemcp-tenants
SOURCES_TABLE=knowledgemcp-sources
ANALYTICS_TABLE=knowledgemcp-analytics

# S3
CONTENT_BUCKET=knowledgemcp-content

# Pre-indexed sites (comma-separated sitemap URLs)
SEED_SITES=https://docs.stripe.com/sitemap.xml,https://docs.mongodb.com/sitemap.xml
