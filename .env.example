# ============================================================
# KnowledgeMCP — environment configuration
# ============================================================
# For local docker-compose use, defaults are fine. Override below only if
# you need to (e.g., switching to AWS mode for production).

# ---- Backend selector --------------------------------------
BACKEND=local                        # local | aws
LOCAL_DATA_DIR=/data                 # SQLite, model cache, JWT secret, uploads

# ---- Embeddings --------------------------------------------
EMBEDDING_PROVIDER=local             # local | bedrock | openai
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5  # only when EMBEDDING_PROVIDER=local
BEDROCK_MODEL_ID=amazon.titan-embed-text-v2:0 # only when EMBEDDING_PROVIDER=bedrock
OPENAI_API_KEY=                      # only when EMBEDDING_PROVIDER=openai

# ---- OpenSearch (used in both modes) -----------------------
OPENSEARCH_ENDPOINT=http://opensearch:9200
OPENSEARCH_COLLECTION_NAME=knowledgemcp
OPENSEARCH_MASTER_USER=
OPENSEARCH_MASTER_PASSWORD=

# ---- Frontend / Auth ---------------------------------------
FRONTEND_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
# Leave empty in local mode — secret auto-generated to $LOCAL_DATA_DIR/jwt.key
JWT_SECRET_KEY=
SKIP_AUTH=false
SIGNUP_CODE=
DEV_AUTH_ALLOW=true                  # enables magic-link via stdout/outbox

# ---- Rate limiting (per tenant) ----------------------------
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=30
MAX_QUERIES_PER_HOUR=100
MAX_DOCS_PER_TENANT=500

# ---- AWS deployment (only when BACKEND=aws) ----------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
TENANTS_TABLE=knowledgemcp-tenants
SOURCES_TABLE=knowledgemcp-sources
ANALYTICS_TABLE=knowledgemcp-analytics
CONTENT_BUCKET=knowledgemcp-content
CRAWL_QUEUE_URL=
INDEX_QUEUE_URL=
SES_FROM_EMAIL=

# ---- Misc --------------------------------------------------
DEBUG=false
USER_AGENT=KnowledgeMCP/1.0 (+https://github.com/hashwnath/KMCP)
CRAWL_DELAY_SECONDS=0.5
MCP_BASE_URL=http://localhost:8000
